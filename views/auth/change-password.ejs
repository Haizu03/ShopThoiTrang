<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="form-container">
            <h4 class="mb-4"><i class="fas fa-key me-2"></i>Đổi mật khẩu</h4>

            <form action="/doi-mat-khau" method="POST">
                <div class="mb-3">
                    <label class="form-label">Mật khẩu cũ</label>
                    <input type="password" name="mat_khau_cu" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu mới</label>
                    <input type="password" name="mat_khau_moi" class="form-control" required minlength="6">
                </div>
                <div class="mb-3">
                    <label class="form-label">Xác nhận mật khẩu mới</label>
                    <input type="password" name="xac_nhan" class="form-control" required minlength="6">
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                </button>
            </form>
        </div>
    </div>
</div>
