<div class="login-container" style="background:#f5f6fa;">
    <div class="row g-0 shadow-lg" style="max-width:900px;width:95%;border-radius:20px;overflow:hidden;min-height:520px;">
        <!-- Left - Fashion Image -->
        <div class="col-lg-5 d-none d-lg-block position-relative">
            <img src="https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?w=600&q=80" 
                 alt="Fashion" style="width:100%;height:100%;object-fit:cover;">
            <div style="position:absolute;inset:0;background:linear-gradient(0deg,rgba(26,26,46,0.85) 0%,rgba(26,26,46,0.4) 100%);"></div>
            <div class="position-absolute bottom-0 start-0 p-4 text-white">
                <h4 class="fw-bold mb-2">Shop Thời Trang</h4>
                <p class="opacity-75 mb-0" style="font-size:0.9rem;">Phong cách thời trang đẳng cấp — Cập nhật xu hướng mới nhất mỗi ngày.</p>
                <div class="d-flex gap-3 mt-3">
                    <div><small class="fw-bold">500+</small><br><small class="opacity-50">Sản phẩm</small></div>
                    <div><small class="fw-bold">1000+</small><br><small class="opacity-50">Khách hàng</small></div>
                </div>
            </div>
        </div>
        <!-- Right - Form -->
        <div class="col-lg-7 bg-white d-flex align-items-center">
            <div class="w-100 p-4 p-lg-5">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" 
                         style="width:60px;height:60px;background:linear-gradient(135deg,#e17055,#fd79a8);">
                        <i class="fas fa-tshirt fa-lg text-white"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Chào mừng trở lại!</h3>
                    <p class="text-muted mb-0">Đăng nhập vào tài khoản của bạn</p>
                </div>
                
                <% if (typeof messages !== 'undefined' && messages.error) { %>
                    <div class="alert alert-danger py-2"><i class="fas fa-exclamation-circle me-1"></i><%= messages.error %></div>
                <% } %>
                <% if (typeof messages !== 'undefined' && messages.success) { %>
                    <div class="alert alert-success py-2"><i class="fas fa-check-circle me-1"></i><%= messages.success %></div>
                <% } %>

                <form action="/dang-nhap" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:0.9rem;">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                            <input type="text" name="ten_dang_nhap" class="form-control border-start-0 bg-light" placeholder="Nhập tên đăng nhập" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size:0.9rem;">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" name="mat_khau" class="form-control border-start-0 bg-light" placeholder="Nhập mật khẩu" required>
                        </div>
                    </div>
                    <button type="submit" class="btn w-100 text-white py-2 fw-semibold" style="background:linear-gradient(135deg,#e17055,#fd79a8);border:none;border-radius:10px;">
                        <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                    </button>
                </form>
                <p class="text-center text-muted mt-3" style="font-size:0.8rem;">
                    Demo Admin: <strong>Lan123 / Lan123</strong>
                </p>
                <div class="text-center mt-2">
                    <span class="text-muted" style="font-size:0.9rem;">Chưa có tài khoản?</span>
                    <a href="/dang-ky" class="fw-semibold text-decoration-none" style="color:#e17055;"> Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>
