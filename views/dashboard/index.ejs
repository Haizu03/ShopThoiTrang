<!-- Thống kê tổng quan -->
<div class="row mb-4">
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-primary"><i class="fas fa-box"></i></div>
                <div class="ms-3">
                    <h3><%= stats.sanPham %></h3>
                    <p>Sản phẩm</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-success"><i class="fas fa-shopping-cart"></i></div>
                <div class="ms-3">
                    <h3><%= stats.donHang %></h3>
                    <p>Đơn hàng</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-info"><i class="fas fa-users"></i></div>
                <div class="ms-3">
                    <h3><%= stats.khachHang %></h3>
                    <p>Khách hàng</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-warning"><i class="fas fa-clock"></i></div>
                <div class="ms-3">
                    <h3><%= stats.donChoXuLy %></h3>
                    <p>Chờ xử lý</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-danger"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="ms-3">
                    <h3><%= stats.spHetHang %></h3>
                    <p>Hết hàng</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="icon bg-success"><i class="fas fa-money-bill-wave"></i></div>
                <div class="ms-3">
                    <h3 style="font-size:1.1rem;"><%= Number(stats.doanhThu).toLocaleString('vi-VN') %>đ</h3>
                    <p>Doanh thu</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ doanh thu -->
<div class="row mb-4">
    <div class="col-md-8 mb-3">
        <div class="chart-container">
            <h5 class="mb-3"><i class="fas fa-chart-line me-2"></i>Doanh thu 7 ngày gần đây</h5>
            <canvas id="revenueChart" height="250"></canvas>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="chart-container">
            <h5 class="mb-3"><i class="fas fa-fire me-2"></i>Sản phẩm bán chạy</h5>
            <% if (spBanChay.length > 0) { %>
                <ul class="list-group list-group-flush">
                    <% spBanChay.forEach((sp, index) => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><%= index + 1 %>. <%= sp.ten_sp %></span>
                            <span class="badge bg-primary rounded-pill"><%= sp.tong_ban %> đã bán</span>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p class="text-muted text-center mt-3">Chưa có dữ liệu</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Đơn hàng gần đây -->
<div class="table-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5><i class="fas fa-clock me-2"></i>Đơn hàng gần đây</h5>
        <a href="/don-hang" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Mã ĐH</th>
                    <th>Khách hàng</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Ngày đặt</th>
                </tr>
            </thead>
            <tbody>
                <% if (donHangGanDay.length > 0) { %>
                    <% donHangGanDay.forEach(dh => { %>
                        <tr>
                            <td><strong><%= dh.ma_dh %></strong></td>
                            <td><%= dh.ten_khach || 'Khách lẻ' %></td>
                            <td class="price"><%= Number(dh.tong_tien).toLocaleString('vi-VN') %>đ</td>
                            <td>
                                <% if (dh.trang_thai === 'cho_xac_nhan') { %>
                                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                <% } else if (dh.trang_thai === 'da_xac_nhan') { %>
                                    <span class="badge bg-primary">Đã xác nhận</span>
                                <% } else if (dh.trang_thai === 'dang_giao') { %>
                                    <span class="badge bg-info">Đang giao</span>
                                <% } else if (dh.trang_thai === 'da_giao') { %>
                                    <span class="badge bg-success">Đã giao</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Đã hủy</span>
                                <% } %>
                            </td>
                            <td><%= new Date(dh.ngay_dat).toLocaleDateString('vi-VN') %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="5" class="text-center text-muted">Chưa có đơn hàng</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
// Biểu đồ doanh thu
const ctx = document.getElementById('revenueChart');
if (ctx) {
    const data = <%- JSON.stringify(doanhThu7Ngay) %>;
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: data.map(d => {
                const date = new Date(d.ngay);
                return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' });
            }),
            datasets: [{
                label: 'Doanh thu (VNĐ)',
                data: data.map(d => d.doanh_thu),
                backgroundColor: 'rgba(108, 92, 231, 0.6)',
                borderColor: '#6c5ce7',
                borderWidth: 2,
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return value.toLocaleString('vi-VN') + 'đ';
                        }
                    }
                }
            },
            plugins: {
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.parsed.y.toLocaleString('vi-VN') + 'đ';
                        }
                    }
                }
            }
        }
    });
}
</script>
