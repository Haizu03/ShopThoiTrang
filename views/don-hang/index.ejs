<div class="d-flex justify-content-between align-items-center mb-3">
    <h5><i class="fas fa-shopping-cart me-2"></i>Danh sách đơn hàng</h5>
    <a href="/don-hang/tao" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Tạo đơn hàng</a>
</div>

<div class="table-container mb-3">
    <form method="GET" class="row g-2 align-items-end">
        <div class="col-md-4">
            <input type="text" name="search" class="form-control" placeholder="Mã ĐH, tên khách hàng ..." value="<%= search %>">
        </div>
        <div class="col-md-3">
            <select name="trang_thai" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="cho_xac_nhan" <%= trangThai === 'cho_xac_nhan' ? 'selected' : '' %>>Chờ xác nhận</option>
                <option value="da_xac_nhan" <%= trangThai === 'da_xac_nhan' ? 'selected' : '' %>>Đã xác nhận</option>
                <option value="dang_giao" <%= trangThai === 'dang_giao' ? 'selected' : '' %>>Đang giao</option>
                <option value="da_giao" <%= trangThai === 'da_giao' ? 'selected' : '' %>>Đã giao</option>
                <option value="da_huy" <%= trangThai === 'da_huy' ? 'selected' : '' %>>Đã hủy</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>Lọc</button>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Mã ĐH</th>
                    <th>Khách hàng</th>
                    <th>Nhân viên</th>
                    <th>Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Ngày đặt</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if (donHangs.length > 0) { %>
                    <% donHangs.forEach(dh => { %>
                        <tr>
                            <td><a href="/don-hang/<%= dh.id %>"><strong><%= dh.ma_dh %></strong></a></td>
                            <td><%= dh.ten_khach || 'Khách lẻ' %></td>
                            <td><%= dh.ten_nv || '---' %></td>
                            <td class="price"><%= Number(dh.tong_tien).toLocaleString('vi-VN') %>đ</td>
                            <td><%= Number(dh.thanh_toan).toLocaleString('vi-VN') %>đ</td>
                            <td>
                                <% if (dh.trang_thai === 'da_giao') { %>
                                    <span class="badge bg-success">Đã giao</span>
                                <% } else if (dh.trang_thai === 'cho_xac_nhan') { %>
                                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                <% } else if (dh.trang_thai === 'da_xac_nhan') { %>
                                    <span class="badge bg-primary">Đã xác nhận</span>
                                <% } else if (dh.trang_thai === 'dang_giao') { %>
                                    <span class="badge bg-info">Đang giao</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Đã hủy</span>
                                <% } %>
                            </td>
                            <td><%= new Date(dh.ngay_dat).toLocaleDateString('vi-VN') %></td>
                            <td>
                                <a href="/don-hang/<%= dh.id %>" class="btn btn-sm btn-info btn-action" title="Chi tiết">
                                    <i class="fas fa-eye text-white"></i>
                                </a>
                                <button onclick="confirmDelete('/don-hang/xoa/<%= dh.id %>', '<%= dh.ma_dh %>')" class="btn btn-sm btn-danger btn-action" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="8" class="text-center text-muted py-4">Không có đơn hàng</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <%- include('../partials/pagination') %>
</div>
