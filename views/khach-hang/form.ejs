<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-container">
            <h5 class="mb-4">
                <i class="fas fa-<%= khachHang ? 'edit' : 'plus' %> me-2"></i>
                <%= khachHang ? 'Cập nhật khách hàng' : 'Thêm khách hàng mới' %>
            </h5>
            <form action="/khach-hang/<%= khachHang ? 'sua/' + khachHang.id : 'them' %>" method="POST">
                <div class="mb-3">
                    <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                    <input type="text" name="ho_ten" class="form-control" value="<%= khachHang ? khachHang.ho_ten : '' %>" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" name="so_dien_thoai" class="form-control" value="<%= khachHang ? khachHang.so_dien_thoai || '' : '' %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= khachHang ? khachHang.email || '' : '' %>">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Giới tính</label>
                    <select name="gioi_tinh" class="form-select">
                        <option value="Nam" <%= (khachHang && khachHang.gioi_tinh === 'Nam') ? 'selected' : '' %>>Nam</option>
                        <option value="Nu" <%= (khachHang && khachHang.gioi_tinh === 'Nu') ? 'selected' : '' %>>Nữ</option>
                        <option value="Khac" <%= (!khachHang || khachHang.gioi_tinh === 'Khac') ? 'selected' : '' %>>Khác</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <textarea name="dia_chi" class="form-control" rows="2"><%= khachHang ? khachHang.dia_chi || '' : '' %></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Lưu</button>
                    <a href="/khach-hang" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
