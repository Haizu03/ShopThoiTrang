<div class="d-flex justify-content-between align-items-center mb-3">
    <h5><i class="fas fa-users me-2"></i>Danh sách khách hàng</h5>
    <a href="/khach-hang/them" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Thêm khách hàng</a>
</div>

<div class="table-container mb-3">
    <form method="GET" class="row g-2 align-items-end">
        <div class="col-md-5">
            <input type="text" name="search" class="form-control" placeholder="Tìm tên, SĐT, email ..." value="<%= search %>">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>Tìm</button>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Họ tên</th>
                    <th>Số ĐT</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Số đơn</th>
                    <th>Tổng chi</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if (khachHangs.length > 0) { %>
                    <% khachHangs.forEach((kh, i) => { %>
                        <tr>
                            <td><%= i + 1 + (currentPageNum - 1) * 10 %></td>
                            <td><strong><%= kh.ho_ten %></strong></td>
                            <td><%= kh.so_dien_thoai || '---' %></td>
                            <td><%= kh.email || '---' %></td>
                            <td><%= kh.dia_chi || '---' %></td>
                            <td><span class="badge bg-info"><%= kh.so_don %></span></td>
                            <td class="price"><%= Number(kh.tong_chi).toLocaleString('vi-VN') %>đ</td>
                            <td>
                                <a href="/khach-hang/sua/<%= kh.id %>" class="btn btn-sm btn-warning btn-action" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button onclick="confirmDelete('/khach-hang/xoa/<%= kh.id %>', '<%= kh.ho_ten %>')" class="btn btn-sm btn-danger btn-action" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="8" class="text-center text-muted py-4">Không có khách hàng</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <%- include('../partials/pagination') %>
</div>
