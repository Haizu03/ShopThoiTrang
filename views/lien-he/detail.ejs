<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5><i class="fas fa-envelope-open me-2"></i>Chi tiết liên hệ</h5>
                <a href="/lien-he" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
            </div>

            <!-- Thong tin nguoi gui -->
            <div class="card border-0 bg-light mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Người gửi:</strong> <%= lienHe.ho_ten %></p>
                            <p class="mb-1"><strong>Email:</strong> <%= lienHe.email || 'Không có' %></p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <p class="mb-1"><strong>Ngày gửi:</strong> <%= new Date(lienHe.ngay_gui).toLocaleString('vi-VN') %></p>
                            <p class="mb-1">
                                <% if (lienHe.trang_thai === 'chua_doc') { %>
                                    <span class="badge bg-danger">Chưa đọc</span>
                                <% } else if (lienHe.trang_thai === 'da_doc') { %>
                                    <span class="badge bg-warning text-dark">Đã đọc</span>
                                <% } else { %>
                                    <span class="badge bg-success">Đã phản hồi</span>
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Noi dung -->
            <div class="mb-4">
                <h6 class="fw-bold text-primary"><i class="fas fa-comment me-1"></i>Chủ đề: <%= lienHe.chu_de %></h6>
                <div class="p-3 bg-white border rounded mt-2" style="white-space: pre-wrap;"><%= lienHe.noi_dung %></div>
            </div>

            <!-- Phan hoi da co -->
            <% if (lienHe.phan_hoi) { %>
            <div class="mb-4">
                <h6 class="fw-bold text-success"><i class="fas fa-reply me-1"></i>Phản hồi từ Admin</h6>
                <div class="p-3 bg-success bg-opacity-10 border border-success rounded mt-2" style="white-space: pre-wrap;"><%= lienHe.phan_hoi %></div>
                <small class="text-muted">Phản hồi lúc: <%= lienHe.ngay_phan_hoi ? new Date(lienHe.ngay_phan_hoi).toLocaleString('vi-VN') : '' %></small>
            </div>
            <% } %>

            <!-- Form phan hoi -->
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="fas fa-reply me-1"></i><%= lienHe.phan_hoi ? 'Cập nhật phản hồi' : 'Phản hồi' %></h6>
                </div>
                <div class="card-body">
                    <form action="/lien-he/phan-hoi/<%= lienHe.id %>" method="POST">
                        <div class="mb-3">
                            <textarea name="phan_hoi" class="form-control" rows="5" required placeholder="Nhập nội dung phản hồi..."><%= lienHe.phan_hoi || '' %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i>Gửi phản hồi</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
