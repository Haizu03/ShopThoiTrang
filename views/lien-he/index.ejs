<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-envelope me-2"></i>Liên hệ từ khách hàng
        <% if (chuaDoc > 0) { %>
            <span class="badge bg-danger"><%= chuaDoc %> chưa đọc</span>
        <% } %>
    </h4>
    <div class="btn-group">
        <a href="/lien-he" class="btn btn-sm <%= !trangThai ? 'btn-primary' : 'btn-outline-primary' %>">Tất cả</a>
        <a href="/lien-he?trang_thai=chua_doc" class="btn btn-sm <%= trangThai === 'chua_doc' ? 'btn-primary' : 'btn-outline-primary' %>">Chưa đọc</a>
        <a href="/lien-he?trang_thai=da_doc" class="btn btn-sm <%= trangThai === 'da_doc' ? 'btn-primary' : 'btn-outline-primary' %>">Đã đọc</a>
        <a href="/lien-he?trang_thai=da_phan_hoi" class="btn btn-sm <%= trangThai === 'da_phan_hoi' ? 'btn-primary' : 'btn-outline-primary' %>">Đã phản hồi</a>
    </div>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th width="5%">#</th>
                    <th>Người gửi</th>
                    <th>Chủ đề</th>
                    <th>Ngày gửi</th>
                    <th>Trạng thái</th>
                    <th width="120"></th>
                </tr>
            </thead>
            <tbody>
                <% if (danhSach.length > 0) { %>
                    <% danhSach.forEach((lh, i) => { %>
                        <tr class="<%= lh.trang_thai === 'chua_doc' ? 'fw-bold' : '' %>" style="cursor:pointer;" onclick="window.location='/lien-he/<%= lh.id %>'">
                            <td><%= i + 1 %></td>
                            <td>
                                <div><%= lh.ho_ten %></div>
                                <small class="text-muted"><%= lh.email || '' %></small>
                            </td>
                            <td>
                                <% if (lh.trang_thai === 'chua_doc') { %><i class="fas fa-circle text-danger me-1" style="font-size:0.5rem;vertical-align:middle;"></i><% } %>
                                <%= lh.chu_de %>
                            </td>
                            <td><%= new Date(lh.ngay_gui).toLocaleString('vi-VN') %></td>
                            <td>
                                <% if (lh.trang_thai === 'chua_doc') { %>
                                    <span class="badge bg-danger">Chưa đọc</span>
                                <% } else if (lh.trang_thai === 'da_doc') { %>
                                    <span class="badge bg-warning text-dark">Đã đọc</span>
                                <% } else { %>
                                    <span class="badge bg-success">Đã phản hồi</span>
                                <% } %>
                            </td>
                            <td onclick="event.stopPropagation()">
                                <a href="/lien-he/<%= lh.id %>" class="btn btn-sm btn-outline-primary" title="Xem"><i class="fas fa-eye"></i></a>
                                <a href="/lien-he/xoa/<%= lh.id %>" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Xóa liên hệ này?')"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">Không có liên hệ nào</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
