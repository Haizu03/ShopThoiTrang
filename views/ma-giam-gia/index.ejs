<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-ticket-alt me-2"></i>Quản lý mã giảm giá</h4>
    <a href="/ma-giam-gia/tao" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Tạo mã mới</a>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Mã code</th>
                    <th>Mô tả</th>
                    <th>Loại</th>
                    <th>Giá trị</th>
                    <th>Đơn tối thiểu</th>
                    <th>Đã dùng</th>
                    <th>Hạn</th>
                    <th>Trạng thái</th>
                    <th width="120"></th>
                </tr>
            </thead>
            <tbody>
                <% if (danhSach.length > 0) { %>
                    <% danhSach.forEach(m => { %>
                        <tr>
                            <td><span class="badge bg-dark fs-6 font-monospace"><%= m.ma_code %></span></td>
                            <td><%= m.mo_ta || '---' %></td>
                            <td>
                                <% if (m.loai_giam === 'phan_tram') { %>
                                    <span class="badge bg-info">Phần trăm</span>
                                <% } else { %>
                                    <span class="badge bg-warning text-dark">Cố định</span>
                                <% } %>
                            </td>
                            <td class="fw-bold">
                                <% if (m.loai_giam === 'phan_tram') { %>
                                    <%= m.gia_tri %>%
                                <% } else { %>
                                    <%= Number(m.gia_tri).toLocaleString('vi-VN') %>đ
                                <% } %>
                            </td>
                            <td><%= Number(m.don_toi_thieu).toLocaleString('vi-VN') %>đ</td>
                            <td><%= m.da_su_dung %>/<%= m.so_luong %></td>
                            <td>
                                <% if (m.ngay_ket_thuc) { %>
                                    <% const isExpired = new Date(m.ngay_ket_thuc) < new Date(); %>
                                    <span class="<%= isExpired ? 'text-danger' : 'text-success' %>">
                                        <%= new Date(m.ngay_ket_thuc).toLocaleDateString('vi-VN') %>
                                        <% if (isExpired) { %><small>(Hết hạn)</small><% } %>
                                    </span>
                                <% } else { %>
                                    <span class="text-muted">Không giới hạn</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (m.trang_thai) { %>
                                    <span class="badge bg-success">Hoạt động</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Tắt</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/ma-giam-gia/sua/<%= m.id %>" class="btn btn-sm btn-outline-primary" title="Sửa"><i class="fas fa-edit"></i></a>
                                <a href="/ma-giam-gia/xoa/<%= m.id %>" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Xóa mã giảm giá này?')"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="9" class="text-center text-muted py-4">Chưa có mã giảm giá nào</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
