<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-container">
            <h5 class="mb-4">
                <i class="fas fa-<%= nhanVien ? 'edit' : 'plus' %> me-2"></i>
                <%= nhanVien ? 'Cập nhật nhân viên' : 'Thêm nhân viên mới' %>
            </h5>
            <form action="/nhan-vien/<%= nhanVien ? 'sua/' + nhanVien.id : 'them' %>" method="POST">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Mã nhân viên <span class="text-danger">*</span></label>
                        <input type="text" name="ma_nv" class="form-control" value="<%= nhanVien ? nhanVien.ma_nv : '' %>" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input type="text" name="ho_ten" class="form-control" value="<%= nhanVien ? nhanVien.ho_ten : '' %>" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" name="so_dien_thoai" class="form-control" value="<%= nhanVien ? nhanVien.so_dien_thoai || '' : '' %>">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= nhanVien ? nhanVien.email || '' : '' %>">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Giới tính</label>
                        <select name="gioi_tinh" class="form-select">
                            <option value="Nam" <%= (nhanVien && nhanVien.gioi_tinh === 'Nam') ? 'selected' : '' %>>Nam</option>
                            <option value="Nu" <%= (nhanVien && nhanVien.gioi_tinh === 'Nu') ? 'selected' : '' %>>Nữ</option>
                            <option value="Khac" <%= (!nhanVien || nhanVien.gioi_tinh === 'Khac') ? 'selected' : '' %>>Khác</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <input type="text" name="dia_chi" class="form-control" value="<%= nhanVien ? nhanVien.dia_chi || '' : '' %>">
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Chức vụ</label>
                        <input type="text" name="chuc_vu" class="form-control" value="<%= nhanVien ? nhanVien.chuc_vu || '' : '' %>">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Lương</label>
                        <input type="number" name="luong" class="form-control" value="<%= nhanVien ? nhanVien.luong : 0 %>" min="0">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Ngày vào làm</label>
                        <input type="date" name="ngay_vao_lam" class="form-control" value="<%= nhanVien && nhanVien.ngay_vao_lam ? new Date(nhanVien.ngay_vao_lam).toISOString().split('T')[0] : '' %>">
                    </div>
                </div>

                <% if (!nhanVien) { %>
                    <hr>
                    <h6 class="text-muted mb-3">Tài khoản đăng nhập (tùy chọn)</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text" name="ten_dang_nhap" class="form-control">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="password" name="mat_khau" class="form-control" minlength="6">
                        </div>
                    </div>
                <% } %>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Lưu</button>
                    <a href="/nhan-vien" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
