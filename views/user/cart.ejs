<h4 class="section-heading"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h4>

<% const cart = typeof gioHang !== 'undefined' ? gioHang : []; %>

<% if (cart.length === 0) { %>
    <div class="text-center py-5">
        <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Giỏ hàng trống</h5>
        <p class="text-muted">Hãy thêm sản phẩm vào giỏ hàng để mua sắm</p>
        <a href="/cua-hang" class="btn btn-primary"><i class="fas fa-store me-2"></i>Tiếp tục mua sắm</a>
    </div>
<% } else { %>
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px;">Hình</th>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width: 120px;">Đơn giá</th>
                            <th class="text-center" style="width: 140px;">Số lượng</th>
                            <th class="text-end" style="width: 130px;">Thành tiền</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let tongTien = 0; %>
                        <% cart.forEach(item => { %>
                            <% const thanhTien = item.gia_ban * item.so_luong; tongTien += thanhTien; %>
                            <tr>
                                <td>
                                    <% if (item.hinh_anh) { %>
                                        <img src="<%= item.hinh_anh %>" alt="<%= item.ten_sp %>" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                    <% } else { %>
                                        <img src="/images/no-image.svg" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/san-pham-chi-tiet/<%= item.san_pham_id %>" class="text-decoration-none fw-semibold text-dark"><%= item.ten_sp %></a>
                                    <% if (item.kich_thuoc || item.mau_sac) { %>
                                        <br><small class="text-muted">
                                            <% if (item.kich_thuoc) { %>Size: <%= item.kich_thuoc %><% } %>
                                            <% if (item.mau_sac) { %> | Màu: <%= item.mau_sac %><% } %>
                                        </small>
                                    <% } %>
                                </td>
                                <td class="text-center"><%= Number(item.gia_ban).toLocaleString('vi-VN') %>đ</td>
                                <td class="text-center">
                                    <form action="/gio-hang/cap-nhat" method="POST" class="d-inline-flex align-items-center">
                                        <input type="hidden" name="san_pham_id" value="<%= item.san_pham_id %>">
                                        <button type="submit" name="so_luong" value="<%= item.so_luong - 1 %>" class="btn btn-sm btn-outline-secondary" <%= item.so_luong <= 1 ? 'disabled' : '' %>>
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <span class="mx-2 fw-semibold" style="min-width: 30px; text-align: center;"><%= item.so_luong %></span>
                                        <button type="submit" name="so_luong" value="<%= item.so_luong + 1 %>" class="btn btn-sm btn-outline-secondary" <%= item.so_luong >= item.ton_kho ? 'disabled' : '' %>>
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </form>
                                </td>
                                <td class="text-end fw-semibold text-danger"><%= Number(thanhTien).toLocaleString('vi-VN') %>đ</td>
                                <td>
                                    <form action="/gio-hang/xoa/<%= item.san_pham_id %>" method="POST">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <a href="/cua-hang" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Tiếp tục mua sắm</a>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <span class="fw-semibold"><%= Number(tongTien).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold fs-5">Tổng cộng:</span>
                        <span class="fw-bold fs-5 text-danger"><%= Number(tongTien).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <a href="/dat-hang" class="btn btn-primary w-100 btn-lg"><i class="fas fa-credit-card me-2"></i>Tiến hành đặt hàng</a>
                </div>
            </div>
        </div>
    </div>
<% } %>
