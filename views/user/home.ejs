<!-- Danh muc -->
<% if (danhMuc.length > 0) { %>
<%
  const catColors = ['#e17055','#0984e3','#00cec9','#6c5ce7','#fdcb6e','#fd79a8'];
  const catIcons = {
    'ao nam': 'fa-tshirt', 'ao nu': 'fa-tshirt', 'ao khoac': 'fa-vest',
    'ao': 'fa-tshirt', 'quan nam': 'fa-socks', 'quan nu': 'fa-socks',
    'quan': 'fa-socks', 'vay': 'fa-dress', 'dam': 'fa-dress',
    'giay': 'fa-shoe-prints', 'dep': 'fa-shoe-prints',
    'phu kien': 'fa-gem', 'tui': 'fa-bag-shopping', 'the thao': 'fa-running',
    'do the thao': 'fa-running', 'mu': 'fa-hat-cowboy'
  };
  function getCatIcon(name) {
    const lower = name.toLowerCase();
    for (const [key, val] of Object.entries(catIcons)) {
      if (lower.includes(key)) return val;
    }
    return 'fa-tag';
  }
%>
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="badge bg-dark rounded-pill px-3 py-2 mb-2">DANH MỤC</span>
            <h4 class="fw-bold mb-0">Mua sắm theo danh mục</h4>
        </div>
        <a href="/cua-hang" class="btn btn-outline-dark btn-sm">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-3">
        <% danhMuc.forEach((dm, idx) => { %>
            <div class="col-6 col-md-4 col-lg-2">
                <a href="/cua-hang?danh_muc=<%= dm.id %>" class="text-decoration-none">
                    <div class="text-center p-3 bg-white rounded-3 shadow-sm h-100 category-card" style="border-bottom: 3px solid <%= catColors[idx % catColors.length] %>;">
                        <div class="mx-auto mb-2 d-flex align-items-center justify-content-center" 
                             style="width:55px;height:55px;border-radius:50%;background:<%= catColors[idx % catColors.length] %>20;">
                            <i class="fas <%= getCatIcon(dm.ten_danh_muc) %>" style="color:<%= catColors[idx % catColors.length] %>;font-size:1.3rem;"></i>
                        </div>
                        <p class="mb-0 fw-semibold text-dark" style="font-size:0.9rem;"><%= dm.ten_danh_muc %></p>
                    </div>
                </a>
            </div>
        <% }); %>
    </div>
</div>
<% } %>

<!-- San pham moi -->
<div class="mb-5" id="sanpham-moi">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="badge bg-dark rounded-pill px-3 py-2 mb-2">MỚI VỀ</span>
            <h4 class="fw-bold mb-0">Sản phẩm mới nhất</h4>
        </div>
        <a href="/cua-hang" class="btn btn-outline-dark btn-sm">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-3">
        <% if (sanPhamMoi.length > 0) { %>
            <% sanPhamMoi.forEach(sp => { %>
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card position-relative">
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2" style="z-index:2;font-size:0.7rem;">Mới</span>
                        <a href="/san-pham-chi-tiet/<%= sp.id %>" class="text-decoration-none">
                            <% if (sp.hinh_anh) { %>
                                <img src="<%= sp.hinh_anh %>" class="card-img-top" alt="<%= sp.ten_sp %>">
                            <% } else { %>
                                <img src="/images/no-image.svg" class="card-img-top" alt="Chưa có hình">
                            <% } %>
                            <div class="card-body pb-1">
                                <p class="product-category mb-1">
                                    <%= sp.ten_danh_muc || 'Chưa phân loại' %>
                                    <% if (sp.gioi_tinh && sp.gioi_tinh !== 'Unisex') { %>
                                        <span class="badge <%= sp.gioi_tinh === 'Nam' ? 'bg-primary' : 'bg-danger' %>" style="font-size:0.65rem;"><%= sp.gioi_tinh %></span>
                                    <% } %>
                                </p>
                                <h6 class="card-title"><%= sp.ten_sp %></h6>
                                <% if (sp.kich_thuoc || sp.mau_sac) { %>
                                    <p class="product-size mb-1">
                                        <% if (sp.kich_thuoc) { %><span class="me-2"><i class="fas fa-ruler me-1"></i><%= sp.kich_thuoc %></span><% } %>
                                        <% if (sp.mau_sac) { %><span><i class="fas fa-palette me-1"></i><%= sp.mau_sac %></span><% } %>
                                    </p>
                                <% } %>
                                <p class="product-price mb-0"><%= Number(sp.gia_ban).toLocaleString('vi-VN') %>đ</p>
                            </div>
                        </a>
                        <div class="px-3 pb-3">
                            <form action="/gio-hang/them" method="POST">
                                <input type="hidden" name="san_pham_id" value="<%= sp.id %>">
                                <input type="hidden" name="so_luong" value="1">
                                <button type="submit" class="btn btn-sm w-100 text-white" style="background:linear-gradient(135deg,#e17055,#fd79a8);border:none;">
                                    <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                <p class="text-muted">Chưa có sản phẩm nào</p>
            </div>
        <% } %>
    </div>
</div>

