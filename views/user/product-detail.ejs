<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/trang-chu">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="/cua-hang">Cửa hàng</a></li>
        <li class="breadcrumb-item active"><%= sanPham.ten_sp %></li>
    </ol>
</nav>

<div class="row">
    <!-- Image -->
    <div class="col-md-5 mb-4">
        <% if (sanPham.hinh_anh) { %>
            <img src="<%= sanPham.hinh_anh %>" class="product-detail-img" alt="<%= sanPham.ten_sp %>">
        <% } else { %>
            <img src="/images/no-image.svg" class="product-detail-img" alt="Chưa có hình">
        <% } %>
    </div>

    <!-- Info -->
    <div class="col-md-7 mb-4">
        <div class="product-detail-info">
            <span class="badge bg-primary mb-2"><%= sanPham.ten_danh_muc || 'Chưa phân loại' %></span>
            <h2><%= sanPham.ten_sp %></h2>
            <p class="text-muted mb-2">Mã SP: <strong><%= sanPham.ma_sp %></strong></p>
            <p class="product-detail-price"><%= Number(sanPham.gia_ban).toLocaleString('vi-VN') %>đ</p>

            <ul class="product-detail-meta">
                <% if (sanPham.kich_thuoc) { %>
                    <li><span><i class="fas fa-ruler me-2"></i>Kích thước</span><span><%= sanPham.kich_thuoc %></span></li>
                <% } %>
                <% if (sanPham.mau_sac) { %>
                    <li><span><i class="fas fa-palette me-2"></i>Màu sắc</span><span><%= sanPham.mau_sac %></span></li>
                <% } %>
                <% if (sanPham.chat_lieu) { %>
                    <li><span><i class="fas fa-layer-group me-2"></i>Chất liệu</span><span><%= sanPham.chat_lieu %></span></li>
                <% } %>
                <li>
                    <span><i class="fas fa-boxes me-2"></i>Tình trạng</span>
                    <span>
                        <% if (sanPham.so_luong > 0) { %>
                            <span class="text-success fw-bold">Còn hàng (<%= sanPham.so_luong %>)</span>
                        <% } else { %>
                            <span class="text-danger fw-bold">Hết hàng</span>
                        <% } %>
                    </span>
                </li>
            </ul>

            <% if (sanPham.mo_ta) { %>
                <div class="mt-3">
                    <h6 class="fw-bold">Mô tả sản phẩm:</h6>
                    <p class="text-muted"><%= sanPham.mo_ta %></p>
                </div>
            <% } %>

            <% if (sanPham.so_luong > 0) { %>
                <form action="/gio-hang/them" method="POST" class="mt-3 d-flex align-items-center gap-2">
                    <input type="hidden" name="san_pham_id" value="<%= sanPham.id %>">
                    <div class="input-group" style="width: 130px;">
                        <button type="button" class="btn btn-outline-secondary" onclick="var i=this.parentNode.querySelector('input');if(parseInt(i.value)>1)i.value=parseInt(i.value)-1;">−</button>
                        <input type="number" name="so_luong" value="1" min="1" max="<%= sanPham.so_luong %>" class="form-control text-center">
                        <button type="button" class="btn btn-outline-secondary" onclick="var i=this.parentNode.querySelector('input');if(parseInt(i.value)< <%= sanPham.so_luong %>)i.value=parseInt(i.value)+1;">+</button>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ</button>
                </form>
            <% } %>

            <a href="/cua-hang" class="btn btn-outline-primary mt-3">
                <i class="fas fa-arrow-left me-2"></i>Quay lại cửa hàng
            </a>
        </div>
    </div>
</div>

<!-- San pham lien quan -->
<% if (lienQuan.length > 0) { %>
<div class="mt-4">
    <h4 class="section-heading"><i class="fas fa-th-large me-2"></i>Sản phẩm liên quan</h4>
    <div class="row">
        <% lienQuan.forEach(sp => { %>
            <div class="col-6 col-md-3 mb-4">
                <a href="/san-pham-chi-tiet/<%= sp.id %>" class="text-decoration-none">
                    <div class="product-card">
                        <% if (sp.hinh_anh) { %>
                            <img src="<%= sp.hinh_anh %>" class="card-img-top" alt="<%= sp.ten_sp %>">
                        <% } else { %>
                            <img src="/images/no-image.svg" class="card-img-top" alt="Chưa có hình">
                        <% } %>
                        <div class="card-body">
                            <h6 class="card-title"><%= sp.ten_sp %></h6>
                            <p class="product-price mb-0"><%= Number(sp.gia_ban).toLocaleString('vi-VN') %>đ</p>
                        </div>
                    </div>
                </a>
            </div>
        <% }); %>
    </div>
</div>
<% } %>
