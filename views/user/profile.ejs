<h4 class="section-heading"><i class="fas fa-user-circle me-2"></i>Thông tin cá nhân</h4>

<% if (messages.success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= messages.success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<% if (messages.error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= messages.error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<div class="row">
    <div class="col-lg-8">
        <form action="/thong-tin" method="POST" enctype="multipart/form-data">
            <!-- Avatar & Thong tin co ban -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-id-card text-primary me-2"></i>Thông tin cơ bản</h5>
                </div>
                <div class="card-body">
                    <!-- Avatar upload -->
                    <div class="text-center mb-4">
                        <div class="position-relative d-inline-block">
                            <% if (profile.hinh_dai_dien) { %>
                                <img src="<%= profile.hinh_dai_dien %>" alt="Avatar" class="rounded-circle" id="avatarPreview"
                                    style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #6c5ce7;">
                            <% } else { %>
                                <div class="d-inline-flex align-items-center justify-content-center rounded-circle" id="avatarPlaceholder"
                                    style="width: 120px; height: 120px; background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%); color: #fff; font-size: 2.5rem; font-weight: 700; border: 4px solid #6c5ce7;">
                                    <%= user.ho_ten ? user.ho_ten.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <img src="" alt="Avatar" class="rounded-circle" id="avatarPreview"
                                    style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #6c5ce7; display: none;">
                            <% } %>
                            <label for="inputAvatar" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 36px; height: 36px; cursor: pointer; border: 2px solid #fff;">
                                <i class="fas fa-camera"></i>
                            </label>
                            <input type="file" id="inputAvatar" name="hinh_dai_dien" accept="image/*" class="d-none" onchange="previewAvatar(this)">
                        </div>
                        <h5 class="mt-3 mb-0"><%= user.ho_ten %></h5>
                        <small class="text-muted">@<%= user.ten_dang_nhap %></small>
                    </div>

                    <hr>
                    <div class="mb-3">
                        <label class="form-label fw-semibold"><i class="fas fa-user me-2"></i>Họ tên</label>
                        <input type="text" name="ho_ten" class="form-control" value="<%= profile.ho_ten %>" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-envelope me-2"></i>Email</label>
                            <input type="email" name="email" class="form-control" value="<%= profile.email || '' %>">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-phone me-2"></i>Số điện thoại</label>
                            <input type="text" name="so_dien_thoai" class="form-control" value="<%= profile.so_dien_thoai || '' %>">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-calendar me-2"></i>Ngày sinh</label>
                            <input type="date" name="ngay_sinh" class="form-control" value="<%= profile.ngay_sinh ? new Date(profile.ngay_sinh).toISOString().split('T')[0] : '' %>">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-venus-mars me-2"></i>Giới tính</label>
                            <select name="gioi_tinh" class="form-select">
                                <option value="">-- Chọn --</option>
                                <option value="Nam" <%= profile.gioi_tinh === 'Nam' ? 'selected' : '' %>>Nam</option>
                                <option value="Nữ" <%= profile.gioi_tinh === 'Nữ' ? 'selected' : '' %>>Nữ</option>
                                <option value="Khác" <%= profile.gioi_tinh === 'Khác' ? 'selected' : '' %>>Khác</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold"><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ</label>
                        <textarea name="dia_chi" class="form-control" rows="2"><%= profile.dia_chi || '' %></textarea>
                    </div>
                </div>
            </div>

            <!-- So do co the -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-ruler-combined text-info me-2"></i>Số đo hình thể</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Thông tin này giúp bạn chọn size quần áo phù hợp hơn. Không bắt buộc.</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-arrows-alt-v me-2 text-success"></i>Chiều cao (cm)</label>
                            <input type="number" name="chieu_cao" class="form-control" value="<%= profile.chieu_cao || '' %>" min="50" max="250" step="0.1" placeholder="VD: 165">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold"><i class="fas fa-weight me-2 text-warning"></i>Cân nặng (kg)</label>
                            <input type="number" name="can_nang" class="form-control" value="<%= profile.can_nang || '' %>" min="20" max="200" step="0.1" placeholder="VD: 55">
                        </div>
                    </div>
                    <hr>
                    <h6 class="fw-bold mb-3"><i class="fas fa-tape me-2 text-danger"></i>Số đo 3 vòng (cm)</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Vòng 1 (Ngực)</label>
                            <div class="input-group">
                                <input type="number" name="vong_1" class="form-control" value="<%= profile.vong_1 || '' %>" min="50" max="150" step="0.1" placeholder="VD: 88">
                                <span class="input-group-text">cm</span>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Vòng 2 (Eo)</label>
                            <div class="input-group">
                                <input type="number" name="vong_2" class="form-control" value="<%= profile.vong_2 || '' %>" min="40" max="150" step="0.1" placeholder="VD: 65">
                                <span class="input-group-text">cm</span>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Vòng 3 (Mông)</label>
                            <div class="input-group">
                                <input type="number" name="vong_3" class="form-control" value="<%= profile.vong_3 || '' %>" min="50" max="150" step="0.1" placeholder="VD: 92">
                                <span class="input-group-text">cm</span>
                            </div>
                        </div>
                    </div>

                    <!-- Goi y size -->
                    <% if (profile.chieu_cao && profile.can_nang) { %>
                    <%
                        const bmi = (profile.can_nang / ((profile.chieu_cao / 100) * (profile.chieu_cao / 100))).toFixed(1);
                        let bmiLabel = '', bmiColor = '';
                        if (bmi < 18.5) { bmiLabel = 'Thiếu cân'; bmiColor = 'info'; }
                        else if (bmi < 25) { bmiLabel = 'Bình thường'; bmiColor = 'success'; }
                        else if (bmi < 30) { bmiLabel = 'Thừa cân'; bmiColor = 'warning'; }
                        else { bmiLabel = 'Béo phì'; bmiColor = 'danger'; }
                    %>
                    <div class="alert alert-<%= bmiColor %> mt-3 mb-0">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <i class="fas fa-heartbeat fa-2x"></i>
                            </div>
                            <div>
                                <strong>Chỉ số BMI: <%= bmi %></strong> - <span><%= bmiLabel %></span>
                                <br><small>BMI = Cân nặng / (Chiều cao)² | Chiều cao: <%= profile.chieu_cao %>cm, Cân nặng: <%= profile.can_nang %>kg</small>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="d-flex gap-2 mb-4">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>Cập nhật thông tin</button>
                <a href="/doi-mat-khau" class="btn btn-outline-secondary btn-lg"><i class="fas fa-key me-2"></i>Đổi mật khẩu</a>
            </div>
        </form>
    </div>

    <!-- Sidebar thong ke -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body text-center">
                <i class="fas fa-shopping-bag fa-2x mb-2" style="color: #6c5ce7;"></i>
                <h3 class="mb-0"><%= typeof tongDonHang !== 'undefined' ? tongDonHang : 0 %></h3>
                <small class="text-muted">Đơn hàng</small>
            </div>
        </div>
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body text-center">
                <i class="fas fa-check-circle fa-2x mb-2 text-success"></i>
                <h3 class="mb-0"><%= typeof donHoanThanh !== 'undefined' ? donHoanThanh : 0 %></h3>
                <small class="text-muted">Hoàn thành</small>
            </div>
        </div>
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body text-center">
                <i class="fas fa-coins fa-2x mb-2 text-warning"></i>
                <h3 class="mb-0"><%= typeof tongChiTieu !== 'undefined' ? Number(tongChiTieu).toLocaleString('vi-VN') : 0 %>đ</h3>
                <small class="text-muted">Tổng chi tiêu</small>
            </div>
        </div>

        <!-- Thong tin so do nhanh -->
        <% if (profile.chieu_cao || profile.can_nang || profile.vong_1) { %>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fas fa-ruler me-2 text-info"></i>Số đo của bạn</h6>
            </div>
            <div class="card-body">
                <% if (profile.chieu_cao) { %>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Chiều cao</span>
                    <span class="fw-bold"><%= profile.chieu_cao %> cm</span>
                </div>
                <% } %>
                <% if (profile.can_nang) { %>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Cân nặng</span>
                    <span class="fw-bold"><%= profile.can_nang %> kg</span>
                </div>
                <% } %>
                <% if (profile.vong_1 || profile.vong_2 || profile.vong_3) { %>
                <hr class="my-2">
                <div class="text-center">
                    <span class="badge bg-primary me-1">V1: <%= profile.vong_1 || '-' %></span>
                    <span class="badge bg-success me-1">V2: <%= profile.vong_2 || '-' %></span>
                    <span class="badge bg-danger">V3: <%= profile.vong_3 || '-' %></span>
                </div>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>
</div>

<script>
function previewAvatar(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const preview = document.getElementById('avatarPreview');
            const placeholder = document.getElementById('avatarPlaceholder');
            preview.src = e.target.result;
            preview.style.display = 'inline-block';
            if (placeholder) placeholder.style.display = 'none';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
