<!-- Search & Filter -->
<div class="shop-search">
    <form action="/cua-hang" method="GET" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-semibold">Tìm kiếm</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" name="q" class="form-control" placeholder="Tìm sản phẩm..." value="<%= timKiem %>">
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">Danh mục</label>
            <select name="danh_muc" class="form-select">
                <option value="">Tất cả danh mục</option>
                <% danhMuc.forEach(dm => { %>
                    <option value="<%= dm.id %>" <%= selectedDanhMuc == dm.id ? 'selected' : '' %>><%= dm.ten_danh_muc %></option>
                <% }); %>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">Giới tính</label>
            <select name="gioi_tinh" class="form-select">
                <option value="">Tất cả</option>
                <option value="Nam" <%= typeof selectedGioiTinh !== 'undefined' && selectedGioiTinh === 'Nam' ? 'selected' : '' %>>Nam</option>
                <option value="Nữ" <%= typeof selectedGioiTinh !== 'undefined' && selectedGioiTinh === 'Nữ' ? 'selected' : '' %>>Nữ</option>
                <option value="Unisex" <%= typeof selectedGioiTinh !== 'undefined' && selectedGioiTinh === 'Unisex' ? 'selected' : '' %>>Unisex</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Lọc</button>
        </div>
    </form>
</div>

<!-- Results info -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Tìm thấy <strong><%= pagination.totalItems %></strong> sản phẩm</p>
</div>

<!-- Product Grid -->
<div class="row">
    <% if (sanPham.length > 0) { %>
        <% sanPham.forEach(sp => { %>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="product-card">
                    <a href="/san-pham-chi-tiet/<%= sp.id %>" class="text-decoration-none">
                        <% if (sp.hinh_anh) { %>
                            <img src="<%= sp.hinh_anh %>" class="card-img-top" alt="<%= sp.ten_sp %>">
                        <% } else { %>
                            <img src="/images/no-image.svg" class="card-img-top" alt="Chưa có hình">
                        <% } %>
                        <div class="card-body pb-1">
                            <p class="product-category mb-1">
                                <%= sp.ten_danh_muc || 'Chưa phân loại' %>
                                <% if (sp.gioi_tinh && sp.gioi_tinh !== 'Unisex') { %>
                                    <span class="badge <%= sp.gioi_tinh === 'Nam' ? 'bg-primary' : 'bg-danger' %>" style="font-size:0.65rem;"><%= sp.gioi_tinh %></span>
                                <% } %>
                            </p>
                            <h6 class="card-title"><%= sp.ten_sp %></h6>
                            <% if (sp.kich_thuoc || sp.mau_sac) { %>
                                <p class="product-size mb-1">
                                    <% if (sp.kich_thuoc) { %><span class="me-2"><i class="fas fa-ruler me-1"></i><%= sp.kich_thuoc %></span><% } %>
                                    <% if (sp.mau_sac) { %><span><i class="fas fa-palette me-1"></i><%= sp.mau_sac %></span><% } %>
                                </p>
                            <% } %>
                            <p class="product-price mb-0"><%= Number(sp.gia_ban).toLocaleString('vi-VN') %>đ</p>
                        </div>
                    </a>
                    <div class="px-3 pb-3">
                        <form action="/gio-hang/them" method="POST">
                            <input type="hidden" name="san_pham_id" value="<%= sp.id %>">
                            <input type="hidden" name="so_luong" value="1">
                            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12 text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <p class="text-muted">Không tìm thấy sản phẩm nào</p>
        </div>
    <% } %>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <% if (pagination.page > 1) { %>
                <li class="page-item">
                    <a class="page-link" href="/cua-hang?page=<%= pagination.page - 1 %>&danh_muc=<%= selectedDanhMuc %>&q=<%= timKiem %>&gioi_tinh=<%= typeof selectedGioiTinh !== 'undefined' ? selectedGioiTinh : '' %>">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
            <% } %>
            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                    <a class="page-link" href="/cua-hang?page=<%= i %>&danh_muc=<%= selectedDanhMuc %>&q=<%= timKiem %>&gioi_tinh=<%= typeof selectedGioiTinh !== 'undefined' ? selectedGioiTinh : '' %>"><%= i %></a>
                </li>
            <% } %>
            <% if (pagination.page < pagination.totalPages) { %>
                <li class="page-item">
                    <a class="page-link" href="/cua-hang?page=<%= pagination.page + 1 %>&danh_muc=<%= selectedDanhMuc %>&q=<%= timKiem %>&gioi_tinh=<%= typeof selectedGioiTinh !== 'undefined' ? selectedGioiTinh : '' %>">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            <% } %>
        </ul>
    </nav>
<% } %>
